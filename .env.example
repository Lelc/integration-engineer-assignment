# ─── Acme ATS (local Laravel app) ───────────────────────────────────────────
APP_NAME="Acme ATS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# Frontend dev server (if proxying API calls)
FRONTEND_URL=http://localhost:5173

# ─── Spark Hire Meet API v2 (sandbox — provided separately) ─────────────────
# Never commit real values. See README.md and INTERVIEWER.md.

SPARKHIRE_API_BASE_URL=https://api.sparkhire.com/v2.0
SPARKHIRE_CLIENT_ID=
SPARKHIRE_CLIENT_SECRET=
SPARKHIRE_REQUESTER_EMAIL=

# Webhook HMAC secret — set when creating the webhook in Spark Hire integration settings
SPARKHIRE_WEBHOOK_SECRET=